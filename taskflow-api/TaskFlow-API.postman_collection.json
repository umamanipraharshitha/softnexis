{
  "info": {
    "name": "TaskFlow API",
    "description": "CRUD test suite for TaskFlow API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "taskId", "value": "1700000000000" }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/health"
      }
    },
    {
      "name": "Get All Tasks",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/tasks"
      }
    },
    {
      "name": "Get Task By ID",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/tasks/{{taskId}}"
      }
    },
    {
      "name": "Create Task",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"text\": \"Test task from Postman\"\n}"
        },
        "url": "{{baseUrl}}/api/tasks"
      }
    },
    {
      "name": "Update Task",
      "request": {
        "method": "PUT",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"text\": \"Updated task\",\n  \"completed\": true\n}"
        },
        "url": "{{baseUrl}}/api/tasks/{{taskId}}"
      }
    },
    {
      "name": "Delete Task",
      "request": {
        "method": "DELETE",
        "url": "{{baseUrl}}/api/tasks/{{taskId}}"
      }
    },
    {
      "name": "Create Task - Bad Request (empty)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"text\": \"\"\n}"
        },
        "url": "{{baseUrl}}/api/tasks"
      }
    },
    {
      "name": "Get Task - Not Found",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/tasks/9999999999999"
      }
    }
  ]
}
